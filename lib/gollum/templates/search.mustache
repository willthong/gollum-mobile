<div id="wiki-wrapper" class="results">
  <div id="head">
    {{>navbar}}

    <h1 class="header-title text-center text-md-left py-4">
      {{t.search_results_for}}
    </h1>
  </div>

{{#has_tags}}
<div class="Box tag-cloud-section">
  <div class="Box-header">
    <span class="text-muted text-uppercase text-small">{{t.browse_by_tag}}</span>
  </div>
  <div class="tag-grid">
    {{#tags}}
    <span class="tag-pill" data-tag="{{tag}}">{{tag}} <span class="pill-count">{{count}}</span></span>
    {{/tags}}
  </div>
</div>
{{/has_tags}}

{{#has_results}}

  {{>pagination}}

<div class="Box Box--condensed search-results" id="search-results">
  <ul>
  <div class="Box-header border-bottom p-0"></div>
  {{#results}}
    <li class="Box-row Box-row--gray search-result">
      <span class="Counter Counter--primary tooltipped tooltipped-w" aria-label="{{filename_count}} hits in filename - {{count}} hits in content">{{filename_count}} - {{count}}</span>&nbsp;
      <span class="text-bold"><a href="{{href}}">{{name}}</a></span>
      <button
        class="btn-link tooltipped tooltipped-w float-right toggle-context"
        aria-label="{{t.aria.show_all}}"
      >
        {{#octicon}}search{{/octicon}}
      </button>
    </li>

    <div class="search-context">
      {{#context}}
      <li class="Box-row border-0"><span class="text-italic">{{.}}</span></li>
      {{/context}}
    </div>
  {{/results}}
  </ul>
</div>
{{/has_results}}

{{#no_results}}
  <p id="no-results">
    {{t.no_results}}
  </p>
{{/no_results}}

<div id="footer" class="mt-4">
  <a class="btn" href="#">{{t.back_to_top}}</a>
</div>

</div>
</div>

{{#has_tags}}
<style>
.tag-cloud-section { margin-bottom: 16px; }
.tag-grid { display: flex; flex-wrap: wrap; gap: 8px; padding: 12px 16px; }
.tag-pill {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 10px; border-radius: 999px;
  font-size: 13px; font-weight: 500; cursor: pointer; user-select: none;
  background: #ddf4ff; color: #0969da;
  border: 1px solid rgba(9,105,218,0.2);
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.tag-pill:hover:not(.selected) { background: #cae8ff; border-color: rgba(9,105,218,0.35); }
.tag-pill.selected { background: #0969da; color: #fff; border-color: #0969da; }
.tag-pill.selected:hover { background: #0550ae; }
.pill-count {
  font-size: 0.78em; opacity: 0.7; font-weight: 400;
  background: rgba(0,0,0,0.08); padding: 1px 6px; border-radius: 999px;
  min-width: 18px; text-align: center;
}
.tag-pill.selected .pill-count { background: rgba(255,255,255,0.2); }
</style>
<script>
// Tag pill toggle – adds/subtracts :tag: tokens from the search input
(function() {
  var selected = new Set();
  var grid = document.querySelector('.tag-grid');
  var input = document.getElementById('search-query');

  if (!grid || !input) return;

  grid.addEventListener('click', function(e) {
    var pill = e.target.closest('.tag-pill');
    if (!pill) return;
    var tag = pill.getAttribute('data-tag');

    if (selected.has(tag)) {
      selected.delete(tag);
      pill.classList.remove('selected');
    } else {
      selected.add(tag);
      pill.classList.add('selected');
    }

    // Combine selected tags (as :tokens:) with any existing free-text
    var raw = input.value;
    var freeText = raw.replace(/:\S+?:/g, '').replace(/\s+/g, ' ').trim();
    var tagPart = Array.from(selected).map(function(t) { return ':' + t + ':'; }).join(' ');
    input.value = [tagPart, freeText].filter(Boolean).join(' ');
  });
})();
</script>
{{/has_tags}}

